# Local dev: при `npm start` URL API можно не задавать — запросы идут через proxy из package.json
# на 127.0.0.1:8000 (тот же origin, без CORS). Явно задавайте только для особых случаев / prod-сборки.
# REACT_APP_API_URL=http://localhost:8000
# Same Web client ID as GOOGLE_OAUTH_CLIENT_ID in backend/.env (Google Cloud Console → OAuth 2.0 Client IDs).
# REACT_APP_GOOGLE_CLIENT_ID=123456789-xxxx.apps.googleusercontent.com
# Production build on the server uses https://api.lumoref.ru (see deploy/deploy.sh, REACT_APP_API_URL).

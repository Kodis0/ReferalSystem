# Django
DJANGO_SECRET_KEY=django-insecure-change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Email (django.core.mail.send_mail). Локально — console.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=Lumo Referral <noreply@lumoref.ru>

# Production через Brevo HTTPS API (если SMTP с VPS недоступен — таймаут на smtp-relay.brevo.com и т.п.):
# EMAIL_BACKEND=core.email_backends.BrevoApiEmailBackend
# BREVO_API_KEY=your-brevo-api-key
# DEFAULT_FROM_EMAIL=Lumo Referral <noreply@lumoref.ru>
# EMAIL_TIMEOUT=10

# RuSender API production:
# EMAIL_BACKEND=core.email_backends.RuSenderApiEmailBackend
# RUSENDER_API_KEY=your-rusender-api-key
# RUSENDER_API_URL=https://api.beta.rusender.ru/api/v1/external-mails/send
# DEFAULT_FROM_EMAIL=Lumo Referral <noreply@lumoref.ru>
# EMAIL_TIMEOUT=10

# Альтернатива: SMTP (на части VPS исходящий SMTP заблокирован провайдером — проверяйте nc/telnet).
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp-relay.brevo.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-brevo-smtp-login
# EMAIL_HOST_PASSWORD=your-brevo-smtp-key
# DEFAULT_FROM_EMAIL=Lumo Referral <noreply@lumoref.ru>

# CORS / CSRF (production: set explicit origins; overrides single FRONTEND_URL)
FRONTEND_URL=http://localhost:3000

# Django cache. Password reset captcha uses the default cache (`pwreset:captcha:*`).
# Local development can stay process-local:
DJANGO_CACHE_BACKEND=django.core.cache.backends.locmem.LocMemCache
DJANGO_CACHE_LOCATION=lumo-referral-local
# Production with multiple Gunicorn workers must use a shared cache. Minimal option
# without Redis: DatabaseCache (run `python manage.py createcachetable` once).
# DJANGO_CACHE_BACKEND=django.core.cache.backends.db.DatabaseCache
# DJANGO_CACHE_LOCATION=django_cache
# Redis example if django-redis is installed/configured:
# DJANGO_CACHE_BACKEND=django_redis.cache.RedisCache
# DJANGO_CACHE_LOCATION=redis://127.0.0.1:6379/1

# Google Sign-In: Web client ID (must match REACT_APP_GOOGLE_CLIENT_ID on the SPA).
# GOOGLE_OAUTH_CLIENT_ID=123456789-xxxx.apps.googleusercontent.com

# VK ID: в настройках приложения укажите Redirect URI = {PUBLIC_API_ORIGIN}/users/token/vk/callback/
# В «Данные для регистрации» и «Доступы» включите Почту. При необходимости: VK_OAUTH_SCOPE=email phone
# VK_OAUTH_APP_ID=
# VK_OAUTH_CLIENT_SECRET=
# VK_OAUTH_REDIRECT_URI=https://api.example.com/users/token/vk/callback/
# VK_OAUTH_SCOPE=email
# Тема окна VK ID: light | dark
# VK_OAUTH_SCHEME=dark
#
# Telegram Login: токен бота из BotFather; публичный API-URL фронта должен совпадать с доменом в /setdomain.
# Callback по умолчанию: {this backend}/users/token/telegram/callback/ — задайте TELEGRAM_LOGIN_REDIRECT_URI, если
# публичный origin API отличается от URL, который строит runserver.
# TELEGRAM_BOT_TOKEN=123456:AA....
# TELEGRAM_LOGIN_REDIRECT_URI=https://api.example.com/users/token/telegram/callback/
# Base URL of this backend as seen by browsers (widget data-rs-api). Leave unset locally to use request URL.
# PUBLIC_API_BASE=https://api.lumoref.ru

# Referrals (optional; defaults shown)
# REFERRAL_ATTRIBUTION_TTL_DAYS=30
# REFERRAL_DEFAULT_COMMISSION_PERCENT=10.00
# MVP: treat Tilda webhooks with amount > 0 as paid for commission when payment status is absent
# or non-definitive (never overrides explicit unpaid paymentstatus). Disable when real payments integrate.
# REFERRAL_MVP_ASSUME_PAID_IF_AMOUNT_PRESENT=false
# Public lead ingest: server-side dedup window for the same identity (seconds). Default 120.
# LEAD_INGEST_DEDUP_WINDOW_SECONDS=120
# Rate limits for POST /public/v1/events/leads (anonymous; DRF format e.g. 120/minute).
# LEAD_INGEST_THROTTLE_IP=120/minute
# LEAD_INGEST_THROTTLE_SITE=600/minute
# Optional: extra ingest debug logs (safe fields). Default off.
# LEAD_INGEST_DEBUG_LOGGING=False

# LK «Статус сервисов» (GET /referrals/platform-service-status/): JSON overrides per service id
# (lumo-owner, lumo-widget, lumo-referral). Example:
# PLATFORM_SERVICE_STATUS_OVERRIDES_JSON={"lumo-widget":{"ok":false,"message":"Плановые работы до 18:00 МСК"}}

# Order webhook (/users/api/orders/): if set, callers must send the same value in
# X-Order-Webhook-Secret or Authorization: Bearer <value>. Leave unset for local DEBUG only.
# ORDER_WEBHOOK_SHARED_SECRET=change-me-long-random
# Optional: log payload key names / missing payment fields (never logs values). Default off.
# ORDER_WEBHOOK_DEBUG_LOGGING=False
# DJANGO_CORS_ALLOWED_ORIGINS=https://lumoref.ru,https://www.lumoref.ru,https://project17993236.tilda.ws
# DJANGO_CSRF_TRUSTED_ORIGINS=https://lumoref.ru,https://www.lumoref.ru,https://api.lumoref.ru

# Database
# For quick local start keep sqlite:
DB_ENGINE=django.db.backends.sqlite3
# Relative paths are resolved under backend/ (same DB when you run migrate from backend/ or runserver from repo root).
DB_NAME=db.sqlite3

# For PostgreSQL, replace values and set:
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=trs_db
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_HOST=localhost
# DB_PORT=5432
#
# WebAuthn / Passkey (optional; по умолчанию rpId и origins выводятся из FRONTEND_URL / DEBUG)
# WEBAUTHN_RP_ID=lumoref.ru
# WEBAUTHN_RP_NAME=LumoRef
# WEBAUTHN_EXPECTED_ORIGINS=https://lumoref.ru,https://www.lumoref.ru

# Production checklist (values only on the server): see ../deploy/lumoref-backend.env.template

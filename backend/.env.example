# Django
DJANGO_SECRET_KEY=django-insecure-change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# CORS / CSRF (production: set explicit origins; overrides single FRONTEND_URL)
FRONTEND_URL=http://localhost:3000
# DJANGO_CORS_ALLOWED_ORIGINS=https://lumoref.ru,https://www.lumoref.ru
# DJANGO_CSRF_TRUSTED_ORIGINS=https://lumoref.ru,https://www.lumoref.ru,https://api.lumoref.ru

# Database
# For quick local start keep sqlite:
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3

# For PostgreSQL, replace values and set:
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=trs_db
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_HOST=localhost
# DB_PORT=5432
#
# Production checklist (values only on the server): see ../deploy/lumoref-backend.env.template
